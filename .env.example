# =============================================================================
# TaskFlow — root environment (used by docker compose)
# =============================================================================
# Copy to `.env` in this directory:
#   cp .env.example .env
# Also copy `backend/.env.example` → `backend/.env` (required for compose).
# =============================================================================

# --- PostgreSQL (db service + DATABASE_URL for backend) ---
DB_USER=taskflow
DB_PASSWORD=taskflow_secret
DB_NAME=taskflow

# --- JWT (required; backend will not start without this) ---
JWT_SECRET=dev-jwt-secret-change-me-use-long-random-string-in-production

# --- AI (optional; task AI features stay disabled if empty) ---
GEMINI_API_KEY=
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest
# GOOGLE_MODEL=

# --- MinIO (object storage for attachments; minio service) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=taskflow-attachments

# --- Attachments (signed URLs; browser hits API on 3001) ---
ATTACHMENTS_PUBLIC_BASE_URL=http://localhost:3001
ATTACHMENTS_URL_SIGNING_SECRET=dev-attachment-signing-secret-change-me

# --- Frontend build (docker-compose build arg; baked into static bundle) ---
# Browser must reach the API; for local Docker this is correct.
VITE_API_URL=http://localhost:3001
