# =============================================================================
# TaskFlow — frontend (Vite + React)
# =============================================================================
# Copy to `.env` or `.env.local` in this directory:
#   cp .env.example .env
# Only variables prefixed with VITE_ are exposed to the browser.
# Never put secrets here — API keys belong in backend / root `.env` only.
# =============================================================================

# Backend API base URL (no trailing slash)
#
# npm run dev (Vite on http://localhost:5173 typically):
VITE_API_URL=http://localhost:3001

# Production build served by Docker Nginx on http://localhost:3000:
# Same value — the browser still calls the API on port 3001.
# VITE_API_URL=http://localhost:3001

# If the UI and API share one public origin behind a reverse proxy, set:
# VITE_API_URL=https://api.yourdomain.com
