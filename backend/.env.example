# =============================================================================
# TaskFlow — backend (NestJS / Fastify)
# =============================================================================
# Local dev:   cp .env.example .env
# Docker:      copy this file to `backend/.env` (compose `env_file`).
#              Compose overrides DATABASE_URL, JWT_SECRET, MinIO, NODE_ENV, etc.
#              from the root `.env`; keep keys here so ConfigModule can read them.
# =============================================================================

# --- Database ---
DB_USER=taskflow
DB_PASSWORD=taskflow_secret
DB_NAME=taskflow
# Local Postgres (npm run start:dev with `docker compose up db`):
DATABASE_URL=postgres://taskflow:taskflow_secret@localhost:5432/taskflow?sslmode=disable
# Inside Docker Compose this is overridden to use host `db` instead of localhost.

# --- Auth ---
JWT_SECRET=dev-jwt-secret-change-me-use-long-random-string-in-production

# --- HTTP ---
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- AI (optional) ---
GEMINI_API_KEY=
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest
# GOOGLE_MODEL=

# --- MinIO (local dev: run `docker compose up minio` — API port 9002 on host) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=taskflow-attachments
# Docker Compose sets MINIO_ENDPOINT=minio and MINIO_PORT=9000 (internal network).

# --- Attachments ---
ATTACHMENTS_PUBLIC_BASE_URL=http://localhost:3001
ATTACHMENTS_URL_SIGNING_SECRET=dev-attachment-signing-secret-change-me

# --- Optional: local file fallback (mostly unused when using MinIO) ---
# UPLOAD_DIR=./uploads

# --- Optional: set to true to run dbmate on startup in development ---
# AUTO_MIGRATE=true
